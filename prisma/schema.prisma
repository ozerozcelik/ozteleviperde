// ÖzTelevi - Ev Tekstili ve Perdeleri
// Prisma Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// KULLANICI VE KİMLİK DOĞRULAMA
// ============================================

// Kullanıcılar
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?   // Hashlenmiş şifre
  phone         String?
  role          String    @default("customer") // customer, admin
  image         String?
  
  // Adres bilgileri
  addresses     String?   // JSON array
  
  // İlişkiler
  accounts      Account[]
  sessions      Session[]
  carts         Cart[]
  orders        Order[]
  favorites     Favorite[]
  appointments  Appointment[]
  updatedPages  ContentPage[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

model ContentPage {
  id             String               @id @default(cuid())
  slug           String               @unique
  title          String
  status         String               @default("draft") // draft, published
  seoTitle       String?
  seoDescription String?
  
  // Hero section
  heroTitle      String?
  heroSubtitle   String?
  heroImage      String?
  heroCtaText   String?
  heroCtaLink   String?
  
  // Section content (JSON for flexibility)
  sections       String?              // JSON array of section data
  
  // Legacy HTML content (still supported)
  htmlContent    String?
  schemaJson     String?
  
  updatedById    String?
  updatedBy      User?                @relation(fields: [updatedById], references: [id])
  publishedAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  versions       ContentPageVersion[]

  @@map("content_pages")
}

model ContentPageVersion {
  id             String      @id @default(cuid())
  pageId         String
  page           ContentPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  version        Int
  title          String
  status         String
  seoTitle       String?
  seoDescription String?
  heroTitle      String?
  heroSubtitle   String?
  heroImage      String?
  heroCtaText   String?
  heroCtaLink   String?
  sections       String?
  htmlContent    String?
  schemaJson     String?
  createdById    String?
  createdAt      DateTime    @default(now())

  @@unique([pageId, version])
  @@map("content_page_versions")
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

// NextAuth Account
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// NextAuth Session
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// NextAuth Verification Token
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ============================================
// ÜRÜN YÖNETİMİ
// ============================================

// Ürünler
model Product {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String
  price       Float
  comparePrice Float?   // İndirimli fiyat karşılaştırması
  currency    String    @default("TRY")
  category    String    // perdeler, tekstiller, yatak-odasi, aksesuarlar
  collection  String?   // Koleksiyon adı
  image       String?
  images      String?   // JSON array of image URLs
  features    String?   // JSON array of features
  tags        String?   // JSON array of tags
  inStock     Boolean   @default(true)
  stock       Int       @default(0)
  featured    Boolean   @default(false)
  order       Int       @default(0)
  rating      Float     @default(0)
  reviewCount Int       @default(0)
  
  // İlişkiler
  cartItems   CartItem[]
  orderItems  OrderItem[]
  favorites   Favorite[]
  reviews     Review[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("products")
}

// Koleksiyonlar
model Collection {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  image       String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("collections")
}

// ============================================
// SEPET VE SİPARİŞ
// ============================================

// Sepet
model Cart {
  id        String     @id @default(cuid())
  userId    String?
  sessionId String?    // Misafir kullanıcılar için
  user      User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  couponId  String?
  coupon    Coupon?    @relation(fields: [couponId], references: [id])
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("carts")
}

// Sepet Ürünleri
model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)
  price     Float   // Sepete eklenirkenki fiyat
  notes     String? // Özel notlar

  @@unique([cartId, productId])
  @@map("cart_items")
}

// Sipariş
model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  
  // Fatura Adresi
  billingName     String
  billingEmail    String
  billingPhone    String
  billingAddress  String
  billingCity     String
  billingPostal   String?
  
  // Teslimat Adresi
  shippingName    String?
  shippingPhone   String?
  shippingAddress String?
  shippingCity    String?
  shippingPostal  String?
  
  // Fiyat Bilgileri
  subtotal        Float
  discount        Float       @default(0)
  shipping        Float       @default(0)
  total           Float
  currency        String      @default("TRY")
  
  // Kupon
  couponId        String?
  coupon          Coupon?     @relation(fields: [couponId], references: [id])
  
  // Durum
  status          String      @default("pending") // pending, confirmed, processing, shipped, delivered, cancelled
  paymentStatus   String      @default("pending") // pending, paid, failed, refunded
  paymentMethod   String?
  
  // Notlar
  notes           String?
  
  items           OrderItem[]
  
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("orders")
}

// Sipariş Ürünleri
model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id])
  productName String
  quantity    Int
  price       Float
  total       Float
  
  @@map("order_items")
}

// Kuponlar
model Coupon {
  id          String    @id @default(cuid())
  code        String    @unique
  type        String    // percentage, fixed
  value       Float     // İndirim miktarı veya yüzdesi
  minAmount   Float?    // Minimum sepet tutarı
  maxDiscount Float?    // Maksimum indirim tutarı
  usageLimit  Int?      // Kullanım limiti
  usedCount   Int       @default(0)
  active      Boolean   @default(true)
  startDate   DateTime?
  endDate     DateTime?
  
  carts       Cart[]
  orders      Order[]
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("coupons")
}

// ============================================
// FAVORİLER VE YORUMLAR
// ============================================

// Favoriler
model Favorite {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("favorites")
}

// Yorumlar
model Review {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String?
  name      String
  email     String
  rating    Int     // 1-5
  title     String?
  comment   String
  approved  Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}

// ============================================
// İLETİŞİM VE FORM
// ============================================

// İletişim formu mesajları
model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    String   @default("new") // new, read, replied, archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("contacts")
}

// Teklif talepleri
model QuoteRequest {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  productType String?  // hangi ürün türü ile ilgileniyor
  message     String
  status      String   @default("new") // new, contacted, quoted, closed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("quote_requests")
}

// Randevular
model Appointment {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  name        String
  email       String
  phone       String
  date        DateTime
  time        String
  type        String   // showroom, home-visit, consultation
  notes       String?
  status      String   @default("pending") // pending, confirmed, completed, cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("appointments")
}

// ============================================
// İÇERİK YÖNETİMİ
// ============================================

// Blog yazıları
model Blog {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String   // HTML veya markdown
  excerpt     String?  // Kısa özet
  category    String?  // dekorasyon, trendler, ipuçları
  image       String?
  author      String?
  tags        String?  // JSON array
  featured    Boolean  @default(false)
  published   Boolean  @default(false)
  viewCount   Int      @default(0)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blogs")
}

// SSS (Sık Sorulan Sorular)
model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?  // genel, urunler, siparis, teslimat, iade
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("faqs")
}

// Bülten aboneleri
model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  active    Boolean  @default(true)
  source    String?  // hangi sayfadan abone oldu
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("newsletters")
}

// ============================================
// ANALİTİK
// ============================================

// Sayfa görüntülemeleri
model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  ip        String?
  sessionId String?
  createdAt DateTime @default(now())

  @@map("page_views")
}

// Site istatistikleri (günlük)
model SiteStats {
  id           String   @id @default(cuid())
  date         DateTime @unique
  pageViews    Int      @default(0)
  visitors     Int      @default(0)
  orders       Int      @default(0)
  revenue      Float    @default(0)
  newUsers     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("site_stats")
}
